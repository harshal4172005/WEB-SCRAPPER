          "jsCode": "const website_id = $('domain-url/wesiteID').first().json.website_id;\nconst url = $('Filter & Deduplicate').first().json.url || '';\n\nreturn {\n  text: typeof $json.data === 'string' ? $json.data : JSON.stringify($json),\n  metadata: {\n    website_id: website_id,\n    url: url\n  }\n};"

    {
      "parameters": {
        "jsCode": "const input = (typeof $json.body === 'object' && $json.body !== null) ? $json.body : $json;\n\nfunction normalizeWebsiteId(value) {\n  const raw = String(value || '').trim();\n  if (!raw) return 'test-website-com';\n\n  return raw\n    .replace(/^https?:\\/\\//i, '')\n    .replace(/^www\\./i, '')\n    .replace(/[#?].*$/, '')\n    .replace(/[^a-z0-9]+/gi, '-')\n    .replace(/-+/g, '-')\n    .replace(/^-|-$/g, '')\n    .toLowerCase();\n}\n\nconst websiteUrl = input.url || input.website_id || input.websiteId || '';\nconst website_id = normalizeWebsiteId(websiteUrl);\n\nreturn [{\n  json: {\n    ...input,\n    website_id,\n    source_url: input.url || input.website_id || input.websiteId || ''\n  }\n}];"
      },

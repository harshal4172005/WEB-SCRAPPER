    {
      "parameters": {
        "jsCode": "const website_id = $('domain-url/wesiteID').first().json.website_id || 'test-website-com';\nconst baseUrl = $('domain-url/wesiteID').first().json.source_url || '';\nconst baseHostMatch = baseUrl.match(/^https?:\\/\\/([^\\/]+)/i);\nconst baseHost = baseHostMatch ? baseHostMatch[1].replace(/^www\\./i, '') : '';\n\nconst firstItem = $input.first().json || {};\nconst rawLinks = Array.isArray(firstItem.links)\n  ? firstItem.links\n  : [firstItem.links].filter(Boolean);\n\nfunction normalizeCandidate(candidate) {\n  if (!candidate) return null;\n  let url = candidate;\n  if (url.startsWith('/')) {\n    url = (baseUrl.match(/^https?:\\/\\/[^\\/]+/i) || [''])[0] + url;\n  }\n  if (!url.match(/^https?:\\/\\//i)) return null;\n  url = url.split('#')[0].split('?')[0];\n  url = url.replace(/\\/$/, '');\n  return url;\n}\n\nconst validLinks = new Set();\nconst homepage = normalizeCandidate(baseUrl);\nif (homepage) {\n  validLinks.add(homepage);\n}\n\nfor (const link of rawLinks) {\n  const fullUrl = normalizeCandidate(link);\n  if (!fullUrl) continue;\n  const hostMatch = fullUrl.match(/^https?:\\/\\/([^\\/]+)/i);\n  if (hostMatch) {\n    const host = hostMatch[1].replace(/^www\\./i, '');\n    if (host === baseHost) {\n      validLinks.add(fullUrl);\n    }\n  }\n}\n\nreturn Array.from(validLinks).map((url) => ({ json: { url, website_id } }));"
      },

    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst fallbackWebsiteId = $('domain-url/wesiteID').first().json.website_id || 'test-website-com';\n\nreturn items.map((item) => {\n  const json = item.json || {};\n  const website_id = json.website_id || json.metadata?.website_id || fallbackWebsiteId;\n  const url = json.url || json.metadata?.url || '';\n  const pageText = typeof json.text === 'string' ? json.text.trim() : '';\n  const fallbackText = typeof json.data === 'string' ? json.data.trim() : '';\n  const content = pageText || fallbackText || '';\n\n  return {\n    json: {\n      text: content,\n      content,\n      website_id,\n      url,\n      metadata: {\n        website_id,\n        url\n      }\n    }\n  };\n});"
      },

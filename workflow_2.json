    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst firstItem = items[0]?.json || {};\nconst website_id = firstItem.metadata?.website_id || firstItem.website_id || 'test-website-com';\nconst frontendBase = 'http://localhost:5174';\n\nlet totalTextLength = 0;\nfor (const item of items) {\n  if (item.json && typeof item.json.text === 'string') {\n    totalTextLength += item.json.text.trim().length;\n  }\n}\n\nif (totalTextLength < 50) {\n  return [{\n    json: {\n      success: false,\n      website_id,\n      error: 'Could not extract text from this website. It likely blocks bots or requires a JavaScript-enabled crawler (like Puppeteer/Firecrawl).'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    success: true,\n    website_id,\n    chatbot_url: frontendBase + '/bot/' + website_id\n  }\n}];"
      },

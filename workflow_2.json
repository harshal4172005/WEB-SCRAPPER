        "id": "extract-links-node",
        "name": "Extract Links",
        "continueOnFail": true,
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "jsCode": "const baseUrl = $('domain-url/wesiteID').first().json.source_url;\nconst urlObj = new URL(baseUrl);\nconst domain = urlObj.hostname;\n\nconst rawLinks = $input.first().json.links || [];\nlet validLinks = new Set();\n\n// Always include the homepage itself\nvalidLinks.add(baseUrl.replace(/\\/$/, ''));\n\nfor (let link of rawLinks) {\n  if (!link) continue;\n  try {\n    let fullUrl = link;\n    if (link.startsWith('/')) {\n      fullUrl = urlObj.origin + link;\n    }\n    \n    const linkObj = new URL(fullUrl);\n    \n    if (linkObj.hostname === domain && !fullUrl.includes('#') && linkObj.protocol.startsWith('http')) {\n      validLinks.add((linkObj.origin + linkObj.pathname).replace(/\\/$/, ''));\n    }\n  } catch (e) {\n  }\n}\n\nreturn Array.from(validLinks).map(url => ({ json: { url } }));"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [1000, 200],

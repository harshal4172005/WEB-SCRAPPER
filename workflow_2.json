      {
        "parameters": {
          "jsCode": "const website_id = $('domain-url/wesiteID').first().json.website_id;\nconst items = $('Format for LangChain').all();\n\nlet totalTextLength = 0;\nfor (let item of items) {\n  if (item.json && typeof item.json.text === 'string') {\n    totalTextLength += item.json.text.trim().length;\n  }\n}\n\nif (totalTextLength < 50) {\n  return [{\n    json: {\n      success: false,\n      error: \"Could not extract text from this website. It likely blocks bots or requires a JavaScript-enabled crawler (like Puppeteer/Firecrawl).\"\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    success: true,\n    website_id: website_id,\n    chatbot_url: `http://localhost:5174/bot/${website_id}`\n  }\n}];"
        },
